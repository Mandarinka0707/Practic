POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_PUBLIC_PORT=55432
POSTGRES_DB=shop
POSTGRES_USER=admin
POSTGRES_PASSWORD=secret

MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=replica

# Cron schedule for ETL container (default: every 1 minute)
# Examples:
#   */5 * * * *   -> every 5 minutes
#   */1 * * * *   -> every 1 minute
ETL_CRON=*/1 * * * *

# Replication behavior
SYNC_WINDOW_LAG_SECONDS=5
LOG_LEVEL=INFO
STATE_DOC_ID=replication_state

